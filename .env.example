# .env.example — 所有人必須依此建立自己的 .env
# 2026-04-19 架構：桌面單機應用，100% 本機 LLM
#
# 兩種 LLM 模式（擇一）：
#   A. 開發中 / 半成品：呼叫遠端 llama.cpp API server（OpenAI-compatible）
#   B. Demo / 正式：bundle llama-cpp-python + GGUF 本機載入（尚未遷移完成）
#
# 目前使用 A 模式，B 所需的 LLAMACPP_MODEL_PATH 等變數先保留註解備用。

# ── LLM backend 選擇 ─────────────────────────────────────────────────────────
EDGE_BACKEND=llamacpp                    # ollama | llamacpp | vllm

# llama.cpp server（模式 A，目前使用）
LLAMACPP_BASE_URL=http://PLACEHOLDER:8080   # 實驗室 Ubuntu server 的 llama-server URL
LLAMACPP_MODEL=gemma-4-e4b                  # 啟動 llama-server 時的 alias / -m 名稱

# Ollama 備援（若切換 EDGE_BACKEND=ollama 才用）
OLLAMA_BASE_URL=http://localhost:11434

# 模式 B：bundled llama-cpp-python（遷移完成後啟用）
# LLAMACPP_MODEL_PATH=./models/gemma-4-e4b-q4_k_m.gguf
# LLAMACPP_N_CTX=8192
# LLAMACPP_N_GPU_LAYERS=-1

# ── Notion（使用者可選整合）──────────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxx

# ── Google Calendar（使用者可選整合）────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/callback

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-prod
# CORS：Vite dev server (5173) 走瀏覽器 walking skeleton；Tauri dev server (1420) 之後殼層包好才用
CORS_ORIGINS=http://localhost:5173,http://localhost:1420
