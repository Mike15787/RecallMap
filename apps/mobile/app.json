{
  "expo": {
    "name": "RecallMap",
    "slug": "recallmap",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "recallmap",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.recallmap.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#030712"
      },
      "package": "com.recallmap.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
